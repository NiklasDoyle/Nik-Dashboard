# ---- Server ----
# Port the Express backend listens on (also serves the built app in production).
PORT=3001

# ---- Fitness (MacroFactor) ----
# Folder to read MacroFactor .xlsx exports from. The newest file (by modified
# time) is parsed, so just drop a new "MacroFactor-*.xlsx" export in here to
# update the fitness pane — no renaming needed. Defaults to ./data
MACROFACTOR_DIR=./data

# ---- Race / Strava box ----
# Your goal race date (YYYY-MM-DD). Drives the countdown progress bar.
RACE_DATE=2026-09-05
# Optional: where the progress bar starts (0%). Defaults to RACE_BLOCK_WEEKS
# before the race.
# RACE_START_DATE=2026-05-16
# RACE_BLOCK_WEEKS=16
# Optional Notion property-name overrides (defaults shown) used to read runs:
# NOTION_DISTANCE_PROP=Distance
# NOTION_UNIT_PROP=Unit
# NOTION_TAGS_PROP=Tags
# NOTION_STATUS_PROP=Status
# NOTION_TARGET_PROP=Target

# ---- Gmail auto-sync (bin/sync-macrofactor.js, run by cron) ----
# Pulls newly-emailed MacroFactor exports into MACROFACTOR_DIR automatically.
# Requires 2-Step Verification, then an "app password":
#   Google Account -> Security -> 2-Step Verification -> App passwords.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=
# Optional tuning:
# GMAIL_MAILBOX=INBOX                       # mailbox to scan
# GMAIL_ATTACHMENT_PATTERN=^MacroFactor.*\.xlsx$  # which attachments to grab (regex, case-insensitive)
# GMAIL_LOOKBACK_DAYS=30                    # only scan mail newer than this

# ---- Notion (workout database) ----
# 1. Create an internal integration at https://www.notion.so/my-integrations
#    and copy its "Internal Integration Secret" here.
NOTION_TOKEN=

# 2. Open your workout database in Notion, click "..." -> Connections -> add
#    your integration so it can read the data.
# 3. Copy the database ID from its URL. For a URL like
#    https://www.notion.so/myworkspace/<DATABASE_ID>?v=...
#    the DATABASE_ID is the 32-char hex string before the "?".
NOTION_DATABASE_ID=

# Exact name of the Date property in that database (case-sensitive).
NOTION_DATE_PROPERTY=Date

# Optional: exact name of the Title property. Leave blank to auto-detect the
# database's title column.
NOTION_TITLE_PROPERTY=

# ---- Google Calendar(s) ----
# For each calendar: Google Calendar -> Settings -> "Settings for my calendars"
# -> pick the calendar -> "Secret address in iCal format" -> copy its URL.
#
# Option A (simple): one URL, or several separated by commas. Each calendar is
# auto-assigned a distinct color.
GOOGLE_ICAL_URL=
# Example for multiple:
# GOOGLE_ICAL_URL=https://calendar.google.com/.../basic.ics,https://calendar.google.com/.../basic.ics
#
# Option B (full control): a JSON array giving each calendar a name and color.
# If set, this takes precedence over GOOGLE_ICAL_URL. Keep it on ONE line and
# WRAP THE WHOLE VALUE IN SINGLE QUOTES — the '#' in the hex colors would
# otherwise be read as a comment and truncate the value.
# GOOGLE_CALENDARS='[{"name":"Personal","url":"https://calendar.google.com/.../basic.ics","color":"#4a8cff"},{"name":"Work","url":"https://calendar.google.com/.../basic.ics","color":"#37b24d"}]'
